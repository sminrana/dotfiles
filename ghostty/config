theme = molokai
term = xterm-256color

font-family = JetBrainsMono Nerd Font
font-family-bold = JetBrainsMono Nerd Font Bold
font-family-italic = JetBrainsMono Nerd Font Italic
font-family-bold-italic = JetBrainsMono Nerd Font Italic
font-style = "Regular"
font-style-bold = "Bold"
font-style-italic = "Italic"
font-thicken = false
font-size = 16
font-feature = calt
font-feature = liga
font-feature = ss01
font-feature = ss02
font-feature = ss03
font-feature = ss04
font-feature = ss05
font-feature = ss06
font-feature = ss09
font-feature = ss08

macos-non-native-fullscreen=visible-menu
fullscreen = non-native-visible-menu
macos-option-as-alt = true
macos-titlebar-style = hidden


working-directory = home
auto-update=download
auto-update-channel=stable
quit-after-last-window-closed = false
confirm-close-surface=false
clipboard-read = allow
mouse-hide-while-typing = true

background-opacity = 0.97
unfocused-split-opacity = 0.35
background-blur=false


adjust-cell-width = 0
adjust-cell-height = 0
window-colorspace = display-p3
window-save-state = always
window-theme = auto
window-decoration=true
window-padding-y = 0
window-padding-x = 2
window-padding-color = extend
window-padding-balance = true


keybind = cmd+s=text:\x13
keybind = super+left=goto_split:left
keybind = super+right=goto_split:right
keybind = super+up=goto_split:top
keybind = super+down=goto_split:bottom
keybind = alt+up=scroll_page_lines:-2
keybind = alt+down=scroll_page_lines:2
keybind = super+shift+left=previous_tab
keybind = super+shift+right=next_tab
keybind = super+r=reload_config
keybind = super+shift+f=toggle_fullscreen
keybind = super+shift+left=resize_split:left,10
keybind = super+shift+right=resize_split:right,10
keybind = super+shift+up=resize_split:up,10
keybind = super+shift+down=resize_split:down,10
keybind = super+shift+e=equalize_splits
keybind = super+shift+t=toggle_tab_overview
keybind = global:cmd+shift+e=toggle_quick_terminal

# tmux keybindings (from alacritty config)
keybind = super+a=text:\x01
keybind = super+t=text:\x01c
keybind = super+[=text:\x01p
keybind = super+]=text:\x01n
keybind = super+.=text:\x01o
keybind = super+shift+x=text:\x01X
keybind = super+1=text:\x011
keybind = super+2=text:\x012
keybind = super+3=text:\x013
keybind = super+4=text:\x014
keybind = super+5=text:\x015
keybind = super+6=text:\x016
keybind = super+7=text:\x017
keybind = super+8=text:\x018
keybind = super+9=text:\x019
